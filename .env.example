# ===== DATABASE =====
DATABASE_URL=postgresql://postgres:password@localhost:5432/refchecks_db

# ===== GOOGLE OAUTH =====
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ===== JWT & SECURITY =====
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== ENVIRONMENT =====
ENVIRONMENT=development

# ===== STATSBOMB =====
STATSBOMB_DATA_REPO=https://github.com/statsbomb/StatsBombOpenData

# ===== API =====
API_TITLE=RefChecks - Football Bias Analysis
API_VERSION=1.0.0
API_DESCRIPTION=Analyze refereeing bias using Statsbomb data

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ===== RENDER DEPLOYMENT =====
# Set these when deploying to Render
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SECRET_KEY=generate-with-openssl-rand-hex-32
# ENVIRONMENT=production