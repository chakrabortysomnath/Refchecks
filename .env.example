# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/refchecks_db

# ===== GOOGLE OAUTH =====
# Client ID is public (also shipped in the frontend). The SECRET must never be
# committed — set the real value only in .env (gitignored) and Render env vars.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== JWT & SECURITY =====
# Generate a strong value: `openssl rand -hex 32`
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== ENVIRONMENT =====
ENVIRONMENT=development

# ===== STATSBOMB DATA =====
STATSBOMB_DATA_REPO=https://github.com/statsbomb/open-data

# ===== API CONFIG =====
API_TITLE=RefChecks - Football Bias Analysis
API_VERSION=1.0.0
API_DESCRIPTION=Analyze refereeing bias using Statsbomb data and community submissions

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,https://refchecks-web.onrender.com

# ===== RENDER DEPLOYMENT =====
# Set these when deploying to Render
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SECRET_KEY=generate-with-openssl-rand-hex-32
# ENVIRONMENT=production
