# Copy to .env for local dev, or set these in the Render Static Site dashboard.
# Vite inlines VITE_* vars at BUILD time, so they must be present before the
# build runs on Render.

# Base URL of the deployed RefChecks backend API (no trailing slash).
VITE_API_URL=https://refchecks-api.onrender.com

# Google OAuth Client ID (same client ID configured on the backend).
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
